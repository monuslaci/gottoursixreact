generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String?   @unique
  passwordHash      String?   @db.Text
  passwordSalt      String?   @db.Text
  emailVerified     DateTime?
  image             String?   @db.Text
  azureObjectId     String?   @unique
  businessPhones    String[]
  userPrincipalName String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  accounts          Account[]
  sessions          Session[]
  createdTopics     Topic[]
  createdSubtopics  Subtopic[]
  topicSubscriptions TopicSubscription[]
  subtopicSubscriptions SubtopicSubscription[]
  createdSuggestions Suggestion[] @relation("SuggestionCreatedBy")
  reviewedSuggestions Suggestion[] @relation("SuggestionReviewedBy")
  discussionPosts   DiscussionPost[]
  postLikes         PostLike[]
  createdConversations Conversation[] @relation("ConversationCreatedBy")
  conversationMemberships ConversationMember[]
  sentMessages      Message[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Topic {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  tags        String[]   @default([])
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  subtopics   Subtopic[]
  subscriptions TopicSubscription[]
  posts       DiscussionPost[]
  suggestions Suggestion[]

  @@index([createdById])
  @@index([deletedAt])
  @@map("topics")
}

model Subtopic {
  id          String   @id @default(cuid())
  topicId     String
  title       String
  slug        String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  subscriptions SubtopicSubscription[]
  posts       DiscussionPost[]

  @@unique([topicId, slug])
  @@index([topicId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("subtopics")
}

enum SuggestionKind {
  TOPIC
  SUBTOPIC
}

enum SuggestionStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model Suggestion {
  id             String           @id @default(cuid())
  kind           SuggestionKind
  topicId        String?
  title          String
  description    String?          @db.Text
  status         SuggestionStatus  @default(PENDING)
  suggestedById  String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  topic          Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  suggestedBy    User?            @relation("SuggestionCreatedBy", fields: [suggestedById], references: [id], onDelete: SetNull)
  reviewedBy     User?            @relation("SuggestionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([kind])
  @@index([status])
  @@index([topicId])
  @@index([suggestedById])
  @@map("suggestions")
}

model TopicSubscription {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([topicId])
  @@map("topic_subscriptions")
}

model SubtopicSubscription {
  id         String   @id @default(cuid())
  userId     String
  subtopicId String
  createdAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic  Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  @@unique([userId, subtopicId])
  @@index([subtopicId])
  @@map("subtopic_subscriptions")
}

model DiscussionPost {
  id           String    @id @default(cuid())
  authorId      String?
  topicId      String?
  subtopicId   String?
  parentPostId String?
  body         String    @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author      User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  topic       Topic?          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopic    Subtopic?       @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  parentPost  DiscussionPost? @relation("PostReplies", fields: [parentPostId], references: [id], onDelete: Cascade)
  replies     DiscussionPost[] @relation("PostReplies")
  likes       PostLike[]

  @@index([authorId])
  @@index([topicId])
  @@index([subtopicId])
  @@index([parentPostId])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model Conversation {
  id            String   @id @default(cuid())
  createdById   String?
  isGroup       Boolean  @default(false)
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy    User?               @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members      ConversationMember[]
  messages     Message[]

  @@index([createdById])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String?
  body           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
